[gd_scene load_steps=3 format=3 uid="uid://dt575dsc83a4b"]

[sub_resource type="GDScript" id="GDScript_7dm0k"]
script/source = "extends Control

var scripted_object

func _ready() -> void:
	
	$parse.pressed.connect(_parse)
	$reload.pressed.connect(
		func():
			script_loader.empty_cache()
			free_scripted_object()
			get_tree().change_scene_to_file(\"res://main.tscn\")
	)



func _parse():
	free_scripted_object()
	scripted_object = script_loader.load_string($HSplitContainer/CodeEdit.text,'scripted_example',true)
	if scripted_object != null:
		if scripted_object is Node:
			add_child(scripted_object)
		$HSplitContainer/RichTextLabel.text = scripted_object.get_script().get_source_code()
	


var mem = '%s / %s'
func _process(_delta: float) -> void:
	var static_mem = OS.get_static_memory_usage()
	var peak_mem = OS.get_static_memory_peak_usage()
	DisplayServer.window_set_title(mem % [String.humanize_size(static_mem),String.humanize_size(peak_mem)])



func free_scripted_object():
	if scripted_object == null: return
	scripted_object.set_script(null)
	if scripted_object is RefCounted:
		scripted_object = null  
	else:
		scripted_object.free()
"

[sub_resource type="GDScript" id="GDScript_ig7tw"]
script/source = "extends TextEdit


func _gui_input(_event: InputEvent) -> void:
	if Input.is_action_just_pressed('comment'): 
		accept_event() ; comment() 
	


func comment() -> void:
	if has_selection():
		var selection = get_line_ranges_from_carets()
		for caret in selection:
			for idx in range(caret.x,caret.y + 1):
				comment_line(idx)
		return
	for caret in get_sorted_carets():
		var idx = get_caret_line(caret) ; comment_line(idx)


func comment_line(idx) -> void:
	var line = get_line(idx)
	var has_comment = line.begins_with('#')
	line = line.remove_chars('#') if has_comment else '#%s' % line
	set_line(idx,line)
	set_caret_column(2 if !has_comment else 0)
"

